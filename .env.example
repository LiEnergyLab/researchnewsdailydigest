# Copy to .env for local runs. In GitHub Actions, set the same names as secrets.

# LLM provider keys — set whichever ones you've chosen in config.yaml.
# You can mix and match (e.g. DeepSeek for scoring, Anthropic for summaries).
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
# Optional override if you proxy DeepSeek through a gateway:
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Email (optional) — example uses Gmail SMTP. For Gmail you need an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com,colleague@example.com

# Telegram (optional)
# 1. Talk to @BotFather → /newbot → grab the token
# 2. Send any message to your new bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=987654321
